{
  "opencollection": "1.0.0",
  "info": {
    "name": "Elasticsearch REST API",
    "version": "9.0"
  },
  "request": {
    "auth": {
      "type": "apikey",
      "key": "Authorization",
      "value": "{{Authorization}}",
      "placement": "header"
    }
  },
  "items": [
    {
      "info": {
        "name": "Search",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Search across all indices",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/_search",
            "params": [
              {
                "name": "q",
                "value": "",
                "type": "query",
                "description": "Lucene query string"
              },
              {
                "name": "size",
                "value": "",
                "type": "query",
                "description": "Number of hits to return"
              }
            ]
          },
          "docs": "Returns search results across all indices in the cluster matching the supplied query parameters or request body."
        },
        {
          "info": {
            "name": "Search a specific index",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/:index/_search",
            "params": [
              {
                "name": "index",
                "value": "",
                "type": "path",
                "description": "Index name or pattern"
              },
              {
                "name": "q",
                "value": "",
                "type": "query"
              }
            ]
          },
          "docs": "Searches documents in the specified index using a query string or request body DSL."
        }
      ]
    },
    {
      "info": {
        "name": "Documents",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get a document by ID",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/:index/_doc/:id",
            "params": [
              {
                "name": "index",
                "value": "",
                "type": "path"
              },
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Get a document by ID"
        },
        {
          "info": {
            "name": "Index a document with explicit ID",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/:index/_doc/:id",
            "params": [
              {
                "name": "index",
                "value": "",
                "type": "path"
              },
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Index a document with explicit ID"
        },
        {
          "info": {
            "name": "Delete a document by ID",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/:index/_doc/:id",
            "params": [
              {
                "name": "index",
                "value": "",
                "type": "path"
              },
              {
                "name": "id",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete a document by ID"
        }
      ]
    },
    {
      "info": {
        "name": "Indices",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Create an index",
            "type": "http"
          },
          "http": {
            "method": "PUT",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/:index",
            "params": [
              {
                "name": "index",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Create an index"
        },
        {
          "info": {
            "name": "Delete an index",
            "type": "http"
          },
          "http": {
            "method": "DELETE",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/:index",
            "params": [
              {
                "name": "index",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Delete an index"
        }
      ]
    },
    {
      "info": {
        "name": "Cluster",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get cluster health",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/_cluster/health"
          },
          "docs": "Get cluster health"
        }
      ]
    },
    {
      "info": {
        "name": "Security",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Get a security role",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://{deployment}.es.{region}.cloud.es.io:9243/_security/role/:name",
            "params": [
              {
                "name": "name",
                "value": "",
                "type": "path"
              }
            ]
          },
          "docs": "Returns the named role definition. Roles can be assigned to users and API keys to grant cluster, index, and application privileges."
        }
      ]
    }
  ],
  "bundled": true
}